// BNO055 verilerini float kullanmadan ondalıklı stringe çeviren yardımcı fonksiyon
void AppendScaledData(char* out, const char* label, int16_t raw, int scale) {
    int32_t val_x100 = (raw * 100) / scale;
    int is_neg = 0;
    if (val_x100 < 0) {
        is_neg = 1;
        val_x100 = -val_x100;
    }
    int i_part = val_x100 / 100;
    int d_part = val_x100 % 100;
    sprintf(out + strlen(out), "%s:%s%d.%02d ", label, is_neg ? "-" : "", i_part, d_part);
}

// BNO055 Başlatma Fonksiyonu
void BNO055_Init(void) {
    uint8_t id = 0;
    // Sensör bağlı mı kontrol et
    HAL_I2C_Mem_Read(&hi2c1, BNO055_ADDR, 0x00, 1, &id, 1, 100);

    if(id == 0xA0) {
        snprintf(uart_buf, sizeof(uart_buf), "BNO055 Bulundu! Baslatiliyor...\r\n");
        HAL_UART_Transmit(&huart2, (uint8_t*)uart_buf, strlen(uart_buf), 100);

        // Sensörü NDOF (9-Eksen Füzyon) moduna al (Register 0x3D -> 0x0C)
        uint8_t op_mode = 0x0C;
        HAL_I2C_Mem_Write(&hi2c1, BNO055_ADDR, 0x3D, 1, &op_mode, 1, 100);
        HAL_Delay(50); // Sensör mod değişimi için bekle
    } else {
        snprintf(uart_buf, sizeof(uart_buf), "BNO055 BULUNAMADI! ID: 0x%02X\r\n", id);
        HAL_UART_Transmit(&huart2, (uint8_t*)uart_buf, strlen(uart_buf), 100);
    }
}

// BNO055 Tüm Verileri Okuma
void BNO055_ReadAllAndPrint(void) {
    uint8_t data[46]; // 0x08'den 0x35'e kadar tek seferde 46 byte okuyacağız

    if (HAL_I2C_Mem_Read(&hi2c1, BNO055_ADDR, 0x08, 1, data, 46, 100) == HAL_OK) {
        char line[128];

        // 1. EULER AÇILARI (Heading, Roll, Pitch) - Scale: 16 LSB = 1 Derece
        line[0] = '\0';
        AppendScaledData(line, "H", (int16_t)((data[19]<<8) | data[18]), 16);
        AppendScaledData(line, "R", (int16_t)((data[21]<<8) | data[20]), 16);
        AppendScaledData(line, "P", (int16_t)((data[23]<<8) | data[22]), 16);
        snprintf(uart_buf, sizeof(uart_buf), "[BNO] EULER  | %s\r\n", line);
        HAL_UART_Transmit(&huart2, (uint8_t*)uart_buf, strlen(uart_buf), 100);

        // 2. LINEAR ACCELERATION (Sadece hareket ivmesi, yerçekimi hariç) - Scale: 100 LSB = 1 m/s2
        line[0] = '\0';
        AppendScaledData(line, "X", (int16_t)((data[33]<<8) | data[32]), 100);
        AppendScaledData(line, "Y", (int16_t)((data[35]<<8) | data[34]), 100);
        AppendScaledData(line, "Z", (int16_t)((data[37]<<8) | data[36]), 100);
        snprintf(uart_buf, sizeof(uart_buf), "[BNO] LINACC | %s\r\n", line);
        HAL_UART_Transmit(&huart2, (uint8_t*)uart_buf, strlen(uart_buf), 100);

        // 3. GYROSCOPE - Scale: 16 LSB = 1 dps
        line[0] = '\0';
        AppendScaledData(line, "X", (int16_t)((data[13]<<8) | data[12]), 16);
        AppendScaledData(line, "Y", (int16_t)((data[15]<<8) | data[14]), 16);
        AppendScaledData(line, "Z", (int16_t)((data[17]<<8) | data[16]), 16);
        snprintf(uart_buf, sizeof(uart_buf), "[BNO] GYRO   | %s\r\n", line);
        HAL_UART_Transmit(&huart2, (uint8_t*)uart_buf, strlen(uart_buf), 100);

        // 4. ACCELEROMETER (Yerçekimi dahil) - Scale: 100 LSB = 1 m/s2
        line[0] = '\0';
        AppendScaledData(line, "X", (int16_t)((data[1]<<8) | data[0]), 100);
        AppendScaledData(line, "Y", (int16_t)((data[3]<<8) | data[2]), 100);
        AppendScaledData(line, "Z", (int16_t)((data[5]<<8) | data[4]), 100);
        snprintf(uart_buf, sizeof(uart_buf), "[BNO] ACCEL  | %s\r\n", line);
        HAL_UART_Transmit(&huart2, (uint8_t*)uart_buf, strlen(uart_buf), 100);

        // 5. SICAKLIK VE KALİBRASYON DURUMU (3 = Tam Kalibre, 0 = Kalibre Edilmemiş)
        uint8_t temp = data[44];
        uint8_t calib = data[45];
        snprintf(uart_buf, sizeof(uart_buf), "[BNO] STAT   | TMP:%dC | CALIB(Sys:%d Gyr:%d Acc:%d Mag:%d)\r\n----------------------------------\r\n",
                 temp, (calib>>6)&3, (calib>>4)&3, (calib>>2)&3, calib&3);
        HAL_UART_Transmit(&huart2, (uint8_t*)uart_buf, strlen(uart_buf), 100);
    } else {
        HAL_UART_Transmit(&huart2, (uint8_t*)"[BNO] OKUMA HATASI!\r\n", 21, 100);
    }
}

// Isı Slave Checksum doğrula
uint8_t VerifyChecksum(uint8_t *buf, uint8_t len) {
    uint8_t calc = 0;
    for (uint8_t i = 0; i < len - 1; i++) {
        calc ^= buf[i];
    }
    return (calc == buf[len - 1]) ? 1 : 0;
}

// Isı Slave Verisini PC'ye gönder
void PrintData(uint8_t *buf) {
    int16_t raw1 = (int16_t)((buf[2] << 8) | buf[3]);
    int16_t raw2 = (int16_t)((buf[4] << 8) | buf[5]);
    int16_t raw3 = (int16_t)((buf[6] << 8) | buf[7]);

    int len = snprintf(uart_buf, sizeof(uart_buf),
        "[ISI] SLAVE:0x%02X | T1:%d.%d C | T2:%d.%d C | T3:%d.%d C\r\n",
        buf[1],
        raw1/10, abs(raw1%10),
        raw2/10, abs(raw2%10),
        raw3/10, abs(raw3%10));

    HAL_UART_Transmit(&huart2, (uint8_t*)uart_buf, len, 100);
}
