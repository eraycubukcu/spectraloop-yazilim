/**
  * @brief  The application entry point.
  * @retval int
  */
int main(void)
{

  /* USER CODE BEGIN 1 */

  /* USER CODE END 1 */

  /* MCU Configuration--------------------------------------------------------*/

  /* Reset of all peripherals, Initializes the Flash interface and the Systick. */
  HAL_Init();

  /* USER CODE BEGIN Init */

  /* USER CODE END Init */

  /* Configure the system clock */
  SystemClock_Config();

  /* USER CODE BEGIN SysInit */

  /* USER CODE END SysInit */

  /* Initialize all configured peripherals */
  MX_GPIO_Init();
  MX_I2C1_Init();
  MX_USART2_UART_Init();
  MX_I2C2_Init();
  /* USER CODE BEGIN 2 */
  // 1. Sensörü Başlat
  BNO055_Init();

  snprintf(uart_buf, sizeof(uart_buf), "Master hazir...\r\n");
  HAL_UART_Transmit(&huart2, (uint8_t*)uart_buf, strlen(uart_buf), 100);
  /* USER CODE END 2 */

  /* Infinite loop */
  /* USER CODE BEGIN WHILE */
  while (1)
  {
    /* USER CODE END WHILE */

    /* USER CODE BEGIN 3 */

      // --- 1. GÖREV: ISI SLAVE'DEN VERİ OKU (hi2c2 KULLANARAK) ---
      HAL_StatusTypeDef status = HAL_I2C_Master_Receive(&hi2c2, SLAVE_ADDR, rx_buffer, PACKET_SIZE, I2C_TIMEOUT);

      if (status == HAL_OK) {
          if (rx_buffer[0] == 0xAA) {
              if (VerifyChecksum(rx_buffer, PACKET_SIZE)) {
                  PrintData(rx_buffer);
              } else {
                  HAL_UART_Transmit(&huart2, (uint8_t*)"[ISI] CHECKSUM HATASI\r\n", 23, 100);
              }
          } else {
              HAL_UART_Transmit(&huart2, (uint8_t*)"[ISI] HEADER HATASI\r\n", 21, 100);
          }
      } else {
          HAL_UART_Transmit(&huart2, (uint8_t*)"[ISI] I2C2 HATA\r\n", 17, 100);
      }

      // --- 2. GÖREV: BNO055'TEN 9 EKSEN VERİ OKU VE YAZDIR (hi2c1) ---
      BNO055_ReadAllAndPrint();

      HAL_Delay(1000); // Saniyede 1 kez sistemi güncelle
  /* USER CODE END 3 */
}

