/**
  * @brief  The application entry point.
  * @retval int
  */
int main(void)
{

  /* USER CODE BEGIN 1 */

  /* USER CODE END 1 */

  /* MCU Configuration--------------------------------------------------------*/

  /* Reset of all peripherals, Initializes the Flash interface and the Systick. */
  HAL_Init();

  /* USER CODE BEGIN Init */

  /* USER CODE END Init */

  /* Configure the system clock */
  SystemClock_Config();

  /* USER CODE BEGIN SysInit */

  /* USER CODE END SysInit */

  /* Initialize all configured peripherals */
  MX_GPIO_Init();
  MX_I2C1_Init();
  MX_USART2_UART_Init();
  /* USER CODE BEGIN 2 */
  BNO055_Init();
  snprintf(uart_buf, sizeof(uart_buf), "Master hazir...\r\n");
   HAL_UART_Transmit(&huart2, (uint8_t*)uart_buf, strlen(uart_buf), 100);

  /* USER CODE END 2 */

  /* Infinite loop */
  /* USER CODE BEGIN WHILE */
  while (1)
  {
    /* USER CODE END WHILE */

    /* USER CODE BEGIN 3 */
     uint32_t last_bno_time = 0;
     uint32_t last_temp_time = 0;



         uint32_t current_time = HAL_GetTick(); // İşlemcinin o anki milisaniyesi

         // --- 1. BNO055 OKUMASI: Her 20 ms'de bir (Saniyede 50 kere) ---
         if (current_time - last_bno_time >= 20)
         {
             last_bno_time = current_time;
             BNO055_ReadAll_Live();
         }

         // --- 2. ISI SLAVE OKUMASI: Her 1000 ms'de bir (Saniyede 1 kere) ---
         if (current_time - last_temp_time >= 1000)
         {
             last_temp_time = current_time;

             HAL_StatusTypeDef status = HAL_I2C_Master_Receive(&hi2c1, SLAVE_ADDR, rx_buffer, PACKET_SIZE, I2C_TIMEOUT);

             if (status == HAL_OK) {
                 if (rx_buffer[0] == 0xAA) {
                     if (VerifyChecksum(rx_buffer, PACKET_SIZE)) {
                         PrintData(rx_buffer);
                     } else {
                         HAL_UART_Transmit(&huart2, (uint8_t*)"CHECKSUM HATASI\r\n", 17, 100);
                     }
                 } else {
                     HAL_UART_Transmit(&huart2, (uint8_t*)"HEADER HATASI\r\n", 15, 100);
                 }
             } else {
                 // Hata durumunda çok fazla Putty mesajı basıp sistemi yormamak için kısa bir uyarı
                 HAL_UART_Transmit(&huart2, (uint8_t*)"I2C HATA\r\n", 10, 100);
             }
         }

  /* USER CODE END 3 */
}

